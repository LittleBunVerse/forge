.PHONY: help build release test lint fmt clippy check clean install run

# -----------------------------------------------------------------------
# 帮助
# -----------------------------------------------------------------------

help: ## 显示可用命令
	@grep -E '^[a-zA-Z_-]+:.*?## .*$$' $(MAKEFILE_LIST) | \
		awk 'BEGIN {FS = ":.*?## "}; {printf "  \033[36m%-15s\033[0m %s\n", $$1, $$2}'

# -----------------------------------------------------------------------
# 构建
# -----------------------------------------------------------------------

build: ## 构建 debug 版本
	cargo build

release: ## 构建 release 版本
	cargo build --release

install: ## 安装到本地 PATH
	cargo install --path .

# -----------------------------------------------------------------------
# 测试
# -----------------------------------------------------------------------

test: ## 运行全部测试
	cargo test -- --test-threads=1

# -----------------------------------------------------------------------
# 代码质量
# -----------------------------------------------------------------------

lint: fmt-check clippy ## 运行全部 lint 检查（格式 + clippy）

fmt: ## 自动格式化代码
	cargo fmt

fmt-check: ## 检查代码格式（不修改）
	cargo fmt --check

clippy: ## 运行 clippy 静态分析
	cargo clippy --all-targets --all-features -- -D warnings

check: ## 快速编译检查（不生成二进制）
	cargo check

# -----------------------------------------------------------------------
# 清理
# -----------------------------------------------------------------------

clean: ## 清理构建产物
	cargo clean

# -----------------------------------------------------------------------
# 开发
# -----------------------------------------------------------------------

run: ## 运行 Forge（debug 模式）
	cargo run

run-help: ## 查看 CLI 帮助
	cargo run -- --help
